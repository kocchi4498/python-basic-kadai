      "source": [
        "import numpy as np\n",
        "\n",
        "A = np.array([[0, 1],\n",
        "              [2, 3],\n",
        "              [4, 5]])\n",
        "\n",
        "B = np.array([[0, 1, 2, 3],\n",
        "              [4, 5, 6, 7]])\n",
        "\n",
        "# 行列積の計算\n",
        "C = np.dot(A, B)\n",
        "\n",
        "# 結果の表示\n",
        "print(\"行列積:\")\n",
        "print(C)\n",
        "\n",
        "# 最大値の表示\n",
        "print(\"最大値:\", np.max(C))"
      ]
    }
  ]
